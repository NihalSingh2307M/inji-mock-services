{
  "id": "vp token example",
  "purpose": "Relying party is requesting your digital ID for the purpose of Self-Authentication",
  "format": {
    "ldp_vc": {
      "proof_type": [
        "RsaSignature2018"
      ]
    }
  },
  "input_descriptors": [
    {
      "id": "sdjwt-vc-any",
      "name": "Any SD-JWT VC",
      "purpose": "Accept any Verifiable Credential in SD-JWT format.",
      "format": {
        "vc+sd-jwt": {
          "sd-jwt_alg_values": [
            "ES256",
            "EdDSA",
            "RS256",
            "ES256K"
          ]
        }
      },
      "constraints": {

      }
    },
    {
      "id": "id card credential",
      "format": {
        "ldp_vc": {
          "proof_type": [
            "Ed25519Signature2020",
            "RsaSignature2018"
          ]
        }
      },
      "constraints": {
        "fields": [
          {
            "path": ["$.credentialSubject.email"],
            "filter": {
              "type": "string",
              "pattern": "@gmail.com"
            }
          }
        ]
      }
    },
    {
      "id": "org.iso.18013.5.1.mDL",
      "format": {
        "mso_mdoc": {
          "alg": ["ES256"]
        }
      },
      "constraints": {
        "fields" : [
          {
            "path": [
              "$['org.iso.18013.5.1']['document_number']"
            ]
          }
        ]
      }
    }
  ]
}
