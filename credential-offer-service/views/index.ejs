<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
  </head>

  <body>
    <p><%= body %></p>
    <img src="<%= qrCodeData %>" alt="QR Code" />
    <% if (typeof deeplink !== 'undefined' && deeplink) { %>
      <div style="margin-top: 12px;">
        <a href="<%= deeplink %>">
          <button type="button">Open in Wallet</button>
        </a>
      </div>
    <% } %>
  </body>
</html>
